import java.io.*;
import java.util.*;

public class Solution {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int tickets = sc.nextInt();
        char refreshment = sc.next().charAt(0);
        char coupon = sc.next().charAt(0);
        char ticketType = sc.next().charAt(0);

        if (tickets < 5 || tickets > 40) {
            System.out.println("Minimum of 5 and Maximum of 40 tickets");
            return;
        }

        double ticketRate;

        if (ticketType == 'k') {
            ticketRate = 75;
        } else if (ticketType == 'q') {
            ticketRate = 150;
        } else {
            System.out.println("Invalid Input");
            return;
        }

        double ticketCost = tickets * ticketRate;

        if (tickets > 20) {
            ticketCost = ticketCost - (ticketCost * 0.10);
        }

        if (coupon == 'y') {
            ticketCost = ticketCost - (ticketCost * 0.02);
        }

        double refreshCost = 0;
        if (refreshment == 'y') {
            refreshCost = tickets * 50;
        }

        double totalCost = ticketCost + refreshCost;

        System.out.printf("Ticket cost:%.2f%n", totalCost);
    }
}
